{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/sports-store run build",
  "outputDirectory": "artifacts/sports-store/dist/public",
  "build": {
    "env": {
      "BASE_PATH": "/",
      "NODE_ENV": "production"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
